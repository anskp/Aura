generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id                 Int         @id @default(autoincrement())
  email              String      @unique(map: "User_email_key")
  password           String
  role               user_role   @default(USER)
  kycStatus          KycStatus   @default(NOT_STARTED)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  kycLevel           String?
  kycRejectionReason String?
  kycReviewedAt      DateTime?
  kycSnapshot        Json?
  sumsubApplicantId  String?     @unique
  asset              asset[]
  p2pSellOrders      p2p_order[] @relation("P2POrderSeller")
  p2pBuyTrades       p2p_trade[] @relation("P2PTradeBuyer")
  wallets            wallet[]
}

model wallet {
  id        Int      @id @default(autoincrement())
  address   String
  chain     String
  userId    Int
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id])

  @@unique([address, chain])
  @@index([userId], map: "wallet_userId_fkey")
}

model asset {
  id               Int           @id @default(autoincrement())
  name             String
  symbol           String
  description      String?       @db.Text
  type             asset_type
  valuation        Decimal
  aiPricing        Decimal?
  aiReasoning      String?       @db.Text
  nav              Decimal?
  por              Decimal?
  tokenAddress     String?
  location         String?
  status           asset_status  @default(PENDING)
  companyName      String?
  companyRegNumber String?
  deploymentTxHash String?
  ownerId          Int
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  user             user          @relation(fields: [ownerId], references: [id], map: "Asset_ownerId_fkey")
  pool             pool?
  token            token?
  transaction      transaction[]

  @@index([ownerId], map: "Asset_ownerId_fkey")
}

model investment {
  id              Int      @id @default(autoincrement())
  poolId          Int
  investorAddress String
  amountPaid      Decimal
  sharesReceived  Decimal
  txHash          String   @unique(map: "Investment_txHash_key")
  createdAt       DateTime @default(now())
  pool            pool     @relation(fields: [poolId], references: [id], map: "Investment_poolId_fkey")

  @@index([poolId], map: "Investment_poolId_fkey")
}

model pool {
  id                Int          @id @default(autoincrement())
  address           String       @unique(map: "Pool_address_key")
  assetId           Int          @unique(map: "Pool_assetId_key")
  stablecoinAddress String
  totalLiquidity    Decimal      @default(0.000000000000000000000000000000)
  totalShares       Decimal      @default(0.000000000000000000000000000000)
  deploymentTxHash  String?
  status            pool_status  @default(ACTIVE)
  createdAt         DateTime     @default(now())
  investment        investment[]
  p2pOrders         p2p_order[]
  asset             asset        @relation(fields: [assetId], references: [id], map: "Pool_assetId_fkey")
}

model token {
  id               Int      @id @default(autoincrement())
  name             String
  symbol           String
  address          String   @unique(map: "Token_address_key")
  assetId          Int      @unique(map: "Token_assetId_key")
  navOracleAddress String?
  porAddress       String?
  deploymentTxHash String?
  createdAt        DateTime @default(now())
  asset            asset    @relation(fields: [assetId], references: [id], map: "Token_assetId_fkey")
}

model transaction {
  id          Int                    @id @default(autoincrement())
  assetId     Int?
  userAddress String
  actionType  transaction_actionType
  txHash      String                 @unique(map: "Transaction_txHash_key")
  status      transaction_status     @default(PENDING)
  createdAt   DateTime               @default(now())
  asset       asset?                 @relation(fields: [assetId], references: [id], map: "Transaction_assetId_fkey")

  @@index([assetId], map: "Transaction_assetId_fkey")
}

model p2p_order {
  id            Int              @id @default(autoincrement())
  poolId        Int
  sellerId      Int
  sellerAddress String
  pricePerShare Decimal
  sharesAmount  Decimal
  sharesFilled  Decimal          @default(0.000000000000000000000000000000)
  status        p2p_order_status @default(OPEN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  pool          pool             @relation(fields: [poolId], references: [id], map: "P2POrder_poolId_fkey")
  seller        user             @relation("P2POrderSeller", fields: [sellerId], references: [id], map: "P2POrder_sellerId_fkey")
  trades        p2p_trade[]

  @@index([poolId], map: "P2POrder_poolId_fkey")
  @@index([sellerId], map: "P2POrder_sellerId_fkey")
}

model p2p_trade {
  id           Int              @id @default(autoincrement())
  orderId      Int
  buyerId      Int
  buyerAddress String
  sharesAmount Decimal
  totalPrice   Decimal
  status       p2p_trade_status @default(MATCHED)
  createdAt    DateTime         @default(now())
  buyer        user             @relation("P2PTradeBuyer", fields: [buyerId], references: [id], map: "P2PTrade_buyerId_fkey")
  order        p2p_order        @relation(fields: [orderId], references: [id], map: "P2PTrade_orderId_fkey")

  @@index([orderId], map: "P2PTrade_orderId_fkey")
  @@index([buyerId], map: "P2PTrade_buyerId_fkey")
}

enum user_role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum transaction_actionType {
  DEPLOY_TOKEN
  MINT_RWA
  DEPLOY_POOL
  DEPOSIT_COLLATERAL
  INVEST
  REDEEM
  SYNC_ORACLE
}

enum asset_type {
  ART
  METAL
  REAL_ESTATE
  CARBON
  OTHER
}

enum transaction_status {
  PENDING
  SUCCESS
  FAILED
}

enum pool_status {
  ACTIVE
  CLOSED
}

enum asset_status {
  PENDING
  APPROVED
  TOKENIZED
  LISTED
  ONBOARDED
}

enum p2p_order_status {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
}

enum p2p_trade_status {
  MATCHED
  SETTLED
  FAILED
}
