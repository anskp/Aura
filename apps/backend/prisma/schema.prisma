generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Asset {
  id               Int          @id @default(autoincrement())
  name             String
  symbol           String
  description      String?      @db.Text
  type             AssetType
  valuation        Decimal
  aiPricing        Decimal?     // AI Recommended Pricing
  aiReasoning      String?      @db.Text
  nav              Decimal?     // Current NAV
  por              Decimal?     // Proof of Reserve value
  tokenAddress     String?      // Deployed ERC3643 address
  location         String?
  status           AssetStatus  @default(PENDING)
  companyName      String?
  companyRegNumber String?
  deploymentTxHash String?
  owner            user         @relation(fields: [ownerId], references: [id])
  ownerId          Int
  token            Token?
  pool             Pool?
  transactions     Transaction[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Token {
  id               Int      @id @default(autoincrement())
  name             String
  symbol           String
  address          String   @unique
  assetId          Int      @unique
  asset            Asset    @relation(fields: [assetId], references: [id])
  navOracleAddress String?  
  porAddress       String?  
  deploymentTxHash String?
  createdAt        DateTime @default(now())
}

model Pool {
  id                Int      @id @default(autoincrement())
  address           String   @unique
  assetId           Int      @unique
  asset             Asset    @relation(fields: [assetId], references: [id])
  stablecoinAddress String   
  totalLiquidity    Decimal  @default(0)
  totalShares       Decimal  @default(0)
  deploymentTxHash  String?
  status            PoolStatus @default(ACTIVE)
  investments       Investment[]
  createdAt         DateTime @default(now())
}

model Transaction {
  id           Int      @id @default(autoincrement())
  assetId      Int?
  asset        Asset?   @relation(fields: [assetId], references: [id])
  userAddress  String
  actionType   TransactionAction
  txHash       String   @unique
  status       TransactionStatus @default(PENDING)
  createdAt    DateTime @default(now())
}

model Investment {
  id              Int      @id @default(autoincrement())
  poolId          Int
  pool            Pool     @relation(fields: [poolId], references: [id])
  investorAddress String
  amountPaid      Decimal  // USDC
  sharesReceived  Decimal  // AURAPS
  txHash          String   @unique
  createdAt       DateTime @default(now())
}

enum TransactionAction {
  DEPLOY_TOKEN
  MINT_RWA
  DEPLOY_POOL
  DEPOSIT_COLLATERAL
  INVEST
  REDEEM
  SYNC_ORACLE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model user {
  id        Int       @id @default(autoincrement())
  email     String    @unique(map: "User_email_key")
  password  String
  role      user_role @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // KYC Fields
  kycStatus          KycStatus @default(NOT_STARTED)
  sumsubApplicantId  String?   @unique
  kycReviewedAt      DateTime?
  kycRejectionReason String?
  kycLevel            String?
  kycSnapshot         Json?
  
  // Relations
  wallets wallet[]
  assets  Asset[]
}

// Troubleshooting - Prisma Errors
//
// After resolving the merge conflicts, I encountered errors where Prisma was missing fields or having naming mismatches. I resolved these with the following steps:
//
// 1. Regenerated Prisma Client: Ran `npx prisma generate` in `apps/backend` to update the client types with the new schema.
// 2. Synced Database: Ran `npx prisma db push --force-reset` to align the database structure with the `schema.prisma` file (renaming models and adding fields).
// 3. Seeded Data: Ran `node prisma/seed/admin.js` to restore the admin user after the database reset.
//
// The application is now up to date and functional.
model wallet {
  id        Int      @id @default(autoincrement())
  address   String
  chain     String
  userId    Int
  createdAt DateTime @default(now())

  user user @relation(fields: [userId], references: [id])

  @@unique([address, chain])
}

enum user_role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum AssetType {
  ART
  METAL
  REAL_ESTATE
  CARBON
  OTHER
}

enum AssetStatus {
  PENDING
  APPROVED
  TOKENIZED
  LISTED
  ONBOARDED
}

enum PoolStatus {
  ACTIVE
  CLOSED
}

